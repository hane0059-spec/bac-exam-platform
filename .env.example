# رابط قاعدة بيانات Neon (PostgreSQL)
# مثال: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# سرّ توقيع الجلسة — اجعله طويلاً وعشوائياً (32 حرفاً فأكثر)
AUTH_SECRET="ضع-هنا-سلسلة-عشوائية-طويلة-وسرية"

# وضع المنصّة (كامل/مبسّط) يُضبَط الآن من لوحة المدير العام في «الإعدادات»،
# لا من متغيّر بيئة — يُخزَّن في قاعدة البيانات (AppSetting).
