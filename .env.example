# رابط قاعدة بيانات Neon (PostgreSQL)
# مثال: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# عند النشر على بيئة serverless (مثل Vercel) استخدم رابط Neon المُجمَّع (Pooled
# connection، من لوحة Neon) وأضِف pgbouncer=true&connection_limit=1 لتفادي
# استنزاف اتصالات القاعدة مع تعدّد الدوال الخادمية:
# postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# اختياري: يسمح بتشغيل seed.ts في بيئة NODE_ENV=production عند الحاجة المتعمَّدة فقط
# (seed.ts يصفّر كل البيانات). اتركه فارغاً دائماً في الإنتاج الحقيقي.
# ALLOW_SEED_IN_PRODUCTION="true"

# سرّ توقيع الجلسة — اجعله طويلاً وعشوائياً (32 حرفاً فأكثر)
AUTH_SECRET="ضع-هنا-سلسلة-عشوائية-طويلة-وسرية"

# وضع المنصّة (كامل/مبسّط) يُضبَط الآن من لوحة المدير العام في «الإعدادات»،
# لا من متغيّر بيئة — يُخزَّن في قاعدة البيانات (AppSetting).
