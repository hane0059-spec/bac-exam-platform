// prisma/schema.prisma
// BacExam Platform — Database Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

// المؤسّسة التعليمية (مدرسة/معهد) — وعاء العزل بين المستخدمين.
model School {
  id        String   @id @default(uuid())
  name      String
  type      String? // "مدرسة" / "معهد"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("schools")
}

enum Gender {
  MALE
  FEMALE
}

// إعدادات المنصّة العامة (مفتاح/قيمة) — يضبطها المدير العام (الخط/الثيم…).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

enum CustomFieldType {
  TEXT
  NUMBER
  SELECT
}

// حقول مخصّصة يعرّفها المدير العام للمستخدمين (مدينة/مدرسة…).
model CustomFieldDef {
  id        String          @id @default(uuid())
  label     String
  fieldKey  String          @unique @map("field_key")
  fieldType CustomFieldType  @default(TEXT) @map("field_type")
  options   String[] // لقوائم SELECT
  required  Boolean         @default(false)
  appliesTo String          @default("ALL") @map("applies_to") // ALL|STUDENT|TEACHER|ADMIN
  orderNum  Int             @default(0) @map("order_num")
  isActive  Boolean         @default(true) @map("is_active")

  @@map("custom_field_defs")
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  MATCHING
  FILL_BLANK
  DIAGRAM_LABEL
  CALCULATION
  ORDER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum QuizMode {
  LINEAR
  ADAPTIVE
  PRACTICE
  TIMED_EXAM
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NodeType {
  START
  QUESTION
  BRANCH
  END
}

enum EdgeCondition {
  CORRECT
  INCORRECT
  ALWAYS
  SCORE_GTE
  SCORE_LTE
  OPTION_SELECTED
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  TIMED_OUT
}

// نوع المرفق: ملف اختبار يرفعه المدرّس، أو صورة إجابة يرفعها الطالب.
enum AttachmentKind {
  EXAM_FILE
  ANSWER_UPLOAD
}

// حالة بلاغ خطأ في سؤال.
enum QuestionReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

// حالة اعتراض الطالب على نتيجة تصحيح يدوي.
enum AppealStatus {
  OPEN
  ACCEPTED
  REJECTED
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  passwordHash String   @map("password_hash")
  role         Role
  gender       Gender
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  isSuperAdmin Boolean  @default(false) @map("is_super_admin") // مدير عام (صلاحية كاملة)
  schoolId     String?  @map("school_id") // المؤسّسة (null = على مستوى المنصّة)
  school       School?  @relation(fields: [schoolId], references: [id])
  customData   Json?    @map("custom_data") // قيم الحقول المخصّصة
  createdById  String?  @map("created_by_id") // المُنشئ للحساب
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy          User?    @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers       User[]   @relation("UserCreator")
  studentProfile     StudentProfile?
  teacherProfile     TeacherProfile?
  teacherSubjects    TeacherSubject[]
  teacherEnrollments StudentEnrollment[] @relation("TeacherEnrollments")
  studentEnrollments StudentEnrollment[] @relation("StudentEnrollments")
  createdQuestions   Question[]
  createdQuizzes     Quiz[]
  examSessions       ExamSession[]
  assignments        QuizAssignment[]    @relation("StudentAssignments")
  givenAssignments   QuizAssignment[]    @relation("TeacherAssignments")
  // ولي الأمر: روابطه بأبنائه؛ والطالب: روابط أوليائه (متعدّد-لمتعدّد).
  parentLinks        ParentLink[]        @relation("ParentLinks")
  studentParents     ParentLink[]        @relation("StudentParents")
  uploadedAttachments Attachment[]       @relation("UploadedBy")
  notifications      Notification[]
  annotations        Annotation[]        @relation("AnnotationAuthor")
  questionReports    QuestionReport[]
  gradeAppeals       GradeAppeal[]       @relation("StudentAppeals")

  @@map("users")
}

// بلاغ طالب عن خطأ في سؤال؛ يراجعه المدرّس المُنشئ.
model QuestionReport {
  id          String               @id @default(uuid())
  questionId  String               @map("question_id")
  question    Question             @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentId   String               @map("student_id")
  student     User                 @relation(fields: [studentId], references: [id])
  sessionId   String?              @map("session_id") // الجلسة التي بُلّغ منها
  reason      String
  status      QuestionReportStatus @default(OPEN)
  teacherNote String?              @map("teacher_note")
  createdAt   DateTime             @default(now()) @map("created_at")
  resolvedAt  DateTime?            @map("resolved_at")

  @@index([questionId, status])
  @@map("question_reports")
}

// اعتراض الطالب على نتيجة اختبار ذي تصحيح يدوي (ورقي/مقالي/قصير/فراغات).
// يراجعه المدرّس مالك الاختبار فيعيد التصحيح ويردّ (قبول/رفض + ملاحظة).
model GradeAppeal {
  id              String       @id @default(uuid())
  sessionId       String       @map("session_id")
  session         ExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId       String       @map("student_id")
  student         User         @relation("StudentAppeals", fields: [studentId], references: [id])
  reason          String
  status          AppealStatus @default(OPEN)
  teacherResponse String?      @map("teacher_response")
  createdAt       DateTime     @default(now()) @map("created_at")
  resolvedAt      DateTime?    @map("resolved_at")

  @@index([sessionId])
  @@index([status])
  @@map("grade_appeals")
}

// إشعار داخل التطبيق لمستخدم (مثل: تصحيح اختبار).
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // GRADED | ...
  message   String
  linkUrl   String?  @map("link_url")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

// تعليق المدرّس على صورة إجابة بموضع نسبي (x,y) من 0 إلى 1.
model Annotation {
  id           String     @id @default(uuid())
  attachmentId String     @map("attachment_id")
  attachment   Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  authorId     String     @map("author_id")
  author       User       @relation("AnnotationAuthor", fields: [authorId], references: [id])
  x            Float // نسبة من عرض الصورة (0..1)
  y            Float // نسبة من ارتفاعها (0..1)
  text         String
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("annotations")
}

// مرفق ثنائي (صورة/PDF) مُخزَّن في القاعدة، يُبَثّ عبر مسار مُصادَق فقط.
model Attachment {
  id           String         @id @default(uuid())
  kind         AttachmentKind
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")
  data         Bytes // المحتوى الثنائي (bytea)
  uploadedById String         @map("uploaded_by_id")
  uploadedBy   User           @relation("UploadedBy", fields: [uploadedById], references: [id])
  // ربط حسب النوع: ملف الاختبار بالاختبار، ورفع الإجابة بالجلسة.
  quizId       String?        @map("quiz_id")
  quiz         Quiz?          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  sessionId    String?        @map("session_id")
  session      ExamSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  annotations  Annotation[]
  createdAt    DateTime       @default(now()) @map("created_at")

  @@map("attachments")
}

// ربط ولي الأمر بطالب (متعدّد-لمتعدّد): ولي ← عدّة طلاب، وطالب ← عدّة أولياء.
model ParentLink {
  id        String   @id @default(uuid())
  parentId  String   @map("parent_id")
  parent    User     @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  studentId String   @map("student_id")
  student   User     @relation("StudentParents", fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([parentId, studentId])
  @@map("parent_links")
}

model StudentProfile {
  id             String     @id @default(uuid())
  userId         String     @unique @map("user_id")
  user           User       @relation(fields: [userId], references: [id])
  studentCode    String     @unique @map("student_code")
  gradeLevelId   String     @map("grade_level_id")
  gradeLevel     GradeLevel @relation(fields: [gradeLevelId], references: [id])
  fatherName     String?    @map("father_name")
  motherName     String?    @map("mother_name")
  address        String?
  parentPhone    String?    @map("parent_phone")
  enrollmentYear Int        @map("enrollment_year")
  isExternal     Boolean    @default(false) @map("is_external") // طالب مستورَد خارجياً

  @@map("student_profiles")
}

model TeacherProfile {
  id            String  @id @default(uuid())
  userId        String  @unique @map("user_id")
  user          User    @relation(fields: [userId], references: [id])
  employeeCode  String  @unique @map("employee_code")
  qualification String?
  bio           String?
  // خاصّية اختيارية يفعّلها المدير عند الطلب: إنشاء اختبارات ورقية/مرفوعة (لتقليل التخزين).
  canFileExams  Boolean @default(false) @map("can_file_exams")
  // إذن المدير للمدرّس بإضافة وإدارة حسابات الطلاب (الإسناد يبقى حرّاً دائماً).
  canManageStudents Boolean @default(false) @map("can_manage_students")

  @@map("teacher_profiles")
}

// ─────────────────────────────────────────────
// ACADEMIC STRUCTURE
// ─────────────────────────────────────────────

model GradeLevel {
  id             String           @id @default(uuid())
  name           String           // "بكالوريا علمي"
  code           String           @unique // "BAC_SCI"
  orderNum       Int              @map("order_num")
  subjects       Subject[]
  studentProfiles StudentProfile[]

  @@map("grade_levels")
}

model Subject {
  id           String     @id @default(uuid())
  name         String     // "الفيزياء والكيمياء"
  code         String     @unique // "PHYS_CHEM"
  gradeLevelId String     @map("grade_level_id")
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id])
  description  String?
  iconUrl      String?    @map("icon_url")
  color        String?    // HEX color
  isActive     Boolean    @default(true) @map("is_active")

  units           Unit[]
  chapters        Chapter[]
  teacherSubjects TeacherSubject[]
  enrollments     StudentEnrollment[]
  questions       Question[]
  quizzes         Quiz[]

  @@map("subjects")
}

// الوحدة: أعلى مستوى في بنية المادة (المادة ← وحدة ← فصل ← درس).
model Unit {
  id          String    @id @default(uuid())
  subjectId   String    @map("subject_id")
  subject     Subject   @relation(fields: [subjectId], references: [id])
  title       String
  orderNum    Int       @default(0) @map("order_num")
  description String?
  chapters    Chapter[]

  @@map("units")
}

model TeacherSubject {
  id           String  @id @default(uuid())
  teacherId    String  @map("teacher_id")
  teacher      User    @relation(fields: [teacherId], references: [id])
  subjectId    String  @map("subject_id")
  subject      Subject @relation(fields: [subjectId], references: [id])
  academicYear String  @map("academic_year") // "2024-2025"

  @@unique([teacherId, subjectId, academicYear])
  @@map("teacher_subjects")
}

model StudentEnrollment {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  student      User     @relation("StudentEnrollments", fields: [studentId], references: [id])
  teacherId    String   @map("teacher_id")
  teacher      User     @relation("TeacherEnrollments", fields: [teacherId], references: [id])
  subjectId    String   @map("subject_id")
  subject      Subject  @relation(fields: [subjectId], references: [id])
  academicYear String   @map("academic_year")
  enrolledAt   DateTime @default(now()) @map("enrolled_at")
  isActive     Boolean  @default(true) @map("is_active")

  @@map("student_enrollments")
}

// ─────────────────────────────────────────────
// QUESTION BANK
// ─────────────────────────────────────────────

model Chapter {
  id          String    @id @default(uuid())
  subjectId   String    @map("subject_id")
  subject     Subject   @relation(fields: [subjectId], references: [id])
  unitId      String?   @map("unit_id")
  unit        Unit?     @relation(fields: [unitId], references: [id])
  title       String
  orderNum    Int       @map("order_num")
  description String?
  concepts    Concept[]
  questions   Question[]

  @@map("chapters")
}

model Concept {
  id          String    @id @default(uuid())
  chapterId   String    @map("chapter_id")
  chapter     Chapter   @relation(fields: [chapterId], references: [id])
  title       String
  description String?
  parentId    String?   @map("parent_id")
  parent      Concept?  @relation("ConceptHierarchy", fields: [parentId], references: [id])
  children    Concept[] @relation("ConceptHierarchy")
  questions   Question[]
  performance StudentConceptPerformance[]

  @@map("concepts")
}

model Question {
  id              String       @id @default(uuid())
  creatorId       String       @map("creator_id")
  creator         User         @relation(fields: [creatorId], references: [id])
  subjectId       String       @map("subject_id")
  subject         Subject      @relation(fields: [subjectId], references: [id])
  chapterId       String?      @map("chapter_id")
  chapter         Chapter?     @relation(fields: [chapterId], references: [id])
  conceptId       String?      @map("concept_id")
  concept         Concept?     @relation(fields: [conceptId], references: [id])
  type            QuestionType
  content         String
  contentHtml     String?      @map("content_html")
  mediaUrls       Json?        @map("media_urls") // [{type, url, alt}]
  difficulty      Difficulty   @default(MEDIUM)
  estimatedTime   Int          @default(60) @map("estimated_time") // seconds
  points          Decimal      @default(1) @db.Decimal(5, 2)
  tags            String[]
  explanation     String?
  explanationHtml String?      @map("explanation_html")
  acceptedAnswers String[]     @map("accepted_answers") // for SHORT_ANSWER
  isActive        Boolean      @default(true) @map("is_active")
  isPublic        Boolean      @default(false) @map("is_public")
  // مُلغى: يُستبعد من حساب الدرجة (بسطاً ومقاماً) في كل الجلسات عند اكتشاف خطأ فيه.
  isCancelled     Boolean      @default(false) @map("is_cancelled")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  options         QuestionOption[]
  matchingPairs   QuestionMatchingPair[]
  quizNodes       QuizNode[]
  studentAnswers  StudentAnswer[]
  reports         QuestionReport[]

  @@map("questions")
}

model QuestionOption {
  id          String   @id @default(uuid())
  questionId  String   @map("question_id")
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label       String   // 'أ', 'ب', 'ج', 'د'
  content     String
  contentHtml String?  @map("content_html")
  mediaUrl    String?  @map("media_url")
  isCorrect   Boolean  @map("is_correct")
  orderNum    Int      @map("order_num")
  explanation String?

  selectedInAnswers StudentAnswer[] @relation("SelectedOptions")

  @@map("question_options")
}

model QuestionMatchingPair {
  id         String   @id @default(uuid())
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  leftItem   String   @map("left_item")
  rightItem  String   @map("right_item")
  orderNum   Int      @map("order_num")

  @@map("question_matching_pairs")
}

// ─────────────────────────────────────────────
// QUIZZES & TREE
// ─────────────────────────────────────────────

model Quiz {
  id            String     @id @default(uuid())
  creatorId     String     @map("creator_id")
  creator       User       @relation(fields: [creatorId], references: [id])
  subjectId     String     @map("subject_id")
  subject       Subject    @relation(fields: [subjectId], references: [id])
  title         String
  description   String?
  mode          QuizMode   @default(LINEAR)
  status        QuizStatus @default(DRAFT)
  accessCode    String?    @unique @map("access_code") // رمز تسلسلي للدخول للاختبار
  allowCodeJoin Boolean    @default(false) @map("allow_code_join") // السماح بالانضمام عبر الرمز
  isFileBased   Boolean    @default(false) @map("is_file_based") // اختبار ورقي/مرفوع (صورة/PDF + تصحيح يدوي)
  startNodeId   String?    @map("start_node_id")
  settings      Json       @default("{}") // { timeLimit, maxAttempts, ... }
  availableFrom DateTime?  @map("available_from")
  availableUntil DateTime? @map("available_until")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  nodes       QuizNode[]
  edges       QuizEdge[]
  sessions    ExamSession[]
  assignments QuizAssignment[]
  attachments Attachment[]

  @@map("quizzes")
}

model QuizNode {
  id         String   @id @default(uuid())
  quizId     String   @map("quiz_id")
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId String?  @map("question_id")
  question   Question? @relation(fields: [questionId], references: [id])
  nodeType   NodeType @map("node_type")
  pointsOverride Decimal? @db.Decimal(5, 2) @map("points_override")
  positionX  Float    @default(0) @map("position_x")
  positionY  Float    @default(0) @map("position_y")
  metadata   Json?

  outgoingEdges QuizEdge[]    @relation("SourceNode")
  incomingEdges QuizEdge[]    @relation("TargetNode")
  sessions      ExamSession[] @relation("CurrentNode")
  studentAnswers StudentAnswer[]

  @@map("quiz_nodes")
}

model QuizEdge {
  id              String        @id @default(uuid())
  quizId          String        @map("quiz_id")
  quiz            Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  sourceNodeId    String        @map("source_node_id")
  sourceNode      QuizNode      @relation("SourceNode", fields: [sourceNodeId], references: [id])
  targetNodeId    String        @map("target_node_id")
  targetNode      QuizNode      @relation("TargetNode", fields: [targetNodeId], references: [id])
  conditionType   EdgeCondition @map("condition_type")
  conditionValue  Json?         @map("condition_value") // { optionId, score }
  label           String?
  priority        Int           @default(0) // لترتيب تقييم الشروط

  @@map("quiz_edges")
}

model QuizAssignment {
  id         String    @id @default(uuid())
  quizId     String    @map("quiz_id")
  quiz       Quiz      @relation(fields: [quizId], references: [id])
  studentId  String?   @map("student_id")
  student    User?     @relation("StudentAssignments", fields: [studentId], references: [id])
  teacherId  String?   @map("teacher_id")
  teacher    User?     @relation("TeacherAssignments", fields: [teacherId], references: [id])
  assignedAt DateTime  @default(now()) @map("assigned_at")
  dueDate    DateTime? @map("due_date")
  // محاولات إضافية ممنوحة لهذا الطالب فوق حدّ الاختبار (لإعادة الامتحان).
  extraAttempts Int    @default(0) @map("extra_attempts")

  @@map("quiz_assignments")
}

// ─────────────────────────────────────────────
// EXAM SESSIONS
// ─────────────────────────────────────────────

model ExamSession {
  id               String        @id @default(uuid())
  studentId        String        @map("student_id")
  student          User          @relation(fields: [studentId], references: [id])
  quizId           String        @map("quiz_id")
  quiz             Quiz          @relation(fields: [quizId], references: [id])
  status           SessionStatus @default(IN_PROGRESS)
  currentNodeId    String?       @map("current_node_id")
  currentNode      QuizNode?     @relation("CurrentNode", fields: [currentNodeId], references: [id])
  pathTaken        String[]      @map("path_taken") // array of node UUIDs
  startedAt        DateTime      @default(now()) @map("started_at")
  completedAt      DateTime?     @map("completed_at")
  timeSpent        Int           @default(0) @map("time_spent") // seconds
  totalScore       Decimal       @default(0) @db.Decimal(6, 2) @map("total_score")
  maxPossibleScore Decimal       @default(0) @db.Decimal(6, 2) @map("max_possible_score")
  percentage       Decimal       @default(0) @db.Decimal(5, 2)
  attemptNumber    Int           @default(1) @map("attempt_number")
  deviceInfo       Json?         @map("device_info")
  ipAddress        String?       @map("ip_address")
  // للاختبار الورقي/المرفوع: بانتظار تصحيح المدرّس + ملاحظته (الدرجة في الحقول أعلاه).
  needsGrading     Boolean       @default(false) @map("needs_grading")
  teacherFeedback  String?       @map("teacher_feedback")

  answers     StudentAnswer[]
  attachments Attachment[]
  appeals     GradeAppeal[]

  @@map("exam_sessions")
}

model StudentAnswer {
  id                String         @id @default(uuid())
  sessionId         String         @map("session_id")
  session           ExamSession    @relation(fields: [sessionId], references: [id])
  questionId        String         @map("question_id")
  question          Question       @relation(fields: [questionId], references: [id])
  nodeId            String         @map("node_id")
  node              QuizNode       @relation(fields: [nodeId], references: [id])
  selectedOptions   QuestionOption[] @relation("SelectedOptions")
  textAnswer        String?        @map("text_answer")
  isCorrect         Boolean        @map("is_correct")
  scoreEarned       Decimal        @default(0) @db.Decimal(5, 2) @map("score_earned")
  needsReview       Boolean        @default(false) @map("needs_review") // بانتظار تصحيح المدرّس
  timeSpent         Int            @default(0) @map("time_spent") // seconds
  hintUsed          Boolean        @default(false) @map("hint_used")
  answeredAt        DateTime       @default(now()) @map("answered_at")

  @@map("student_answers")
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

model StudentConceptPerformance {
  id            String   @id @default(uuid())
  studentId     String   @map("student_id")
  conceptId     String   @map("concept_id")
  concept       Concept  @relation(fields: [conceptId], references: [id])
  subjectId     String   @map("subject_id")
  totalAttempts Int      @default(0) @map("total_attempts")
  correctCount  Int      @default(0) @map("correct_count")
  masteryScore  Decimal  @default(0) @db.Decimal(5, 2) @map("mastery_score")
  lastPracticed DateTime? @map("last_practiced")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([studentId, conceptId])
  @@map("student_concept_performance")
}
